# ─────────────────────────────────────────────────────────────
# OpenClaw + GLM-5.1-FP8 — Railway Environment Variables
# ─────────────────────────────────────────────────────────────

# === GATEWAY ===
OPENCLAW_GATEWAY_PORT=8080
OPENCLAW_GATEWAY_TOKEN=          # Generate with: openssl rand -hex 32
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace

# === VERTEX AI (GLM-5.1-FP8) ===
# Option A: Full endpoint URL (if you know it)
# VERTEX_ENDPOINT_URL=https://us-central1-aiplatform.googleapis.com/v1beta1/projects/YOUR_PROJECT/locations/us-central1/endpoints/YOUR_ENDPOINT_ID

# Option B: Components (entrypoint constructs the URL)
VERTEX_PROJECT_ID=               # Your Google Cloud project ID
VERTEX_REGION=us-west1            # Region where your endpoint is deployed
VERTEX_ENDPOINT_ID=              # The dedicated endpoint ID from Model Garden

# Option C: Direct token (skip auto-refresh — you manage token rotation)
# VERTEX_ACCESS_TOKEN=ya29....

# Service account key (base64-encoded JSON) for automatic token refresh
# Generate with: cat sa-key.json | base64 -w0
GOOGLE_SA_KEY_BASE64=

# === SENPI MCP ===
# Your Senpi MCP server URL and auth token
SENPI_MCP_URL=https://mcp.senpi.ai
SENPI_API_TOKEN=                 # Your Senpi API token
